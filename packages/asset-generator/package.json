{
  "name": "@mui-gamebook/asset-generator",
  "version": "0.0.1",
  "description": "Generates AI assets and uploads to Cloudflare R2 for MUI Gamebook",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "tsx src/index.ts",
    "batch": "tsx src/batch-generate.ts --config configs/corlenka.my.json",
    "enhance": "tsx src/ai-enhance.ts",
    "check": "tsx src/check-images.ts",
    "upload": "tsx src/upload-content.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@google/genai": "^2.10.0",
    "@mui-gamebook/core": "workspace:*",
    "@mui-gamebook/parser": "workspace:*",
    "dotenv": "^17.4.2",
    "openai": "^6.45.0",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  },
  "type": "module"
}
