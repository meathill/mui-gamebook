{
  "name": "@mui-gamebook/app",
  "version": "0.8.7",
  "private": true,
  "exports": {
    "./components/GamePlayer": "./src/components/GamePlayer.tsx",
    "./components/Dialog": "./src/components/Dialog.tsx",
    "./components/ShareButton": "./src/components/ShareButton.tsx",
    "./components/game-player": "./src/components/game-player/index.ts",
    "./hooks/useAudioPlayer": "./src/hooks/useAudioPlayer.ts",
    "./lib/games": "./src/lib/games.ts"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 3020",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "cp ../../DSL_SPEC.md ./public && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply mui-gamebook --local",
    "db:migrate:remote": "wrangler d1 migrations apply mui-gamebook --remote",
    "test": "vitest",
    "index-now": "node --experimental-strip-types scripts/index-now.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@mdx-js/loader": "^3.1.1",
