# Next.js 构建期环境变量示例（NEXT_PUBLIC_* 会打进客户端产物）
#
# 本地开发：cp .env.example .env 后按需填写（.env 已 gitignore）
# 机密变量不要放这里，放 .dev.vars（见 .dev.vars.example）

# 站点地址（服务端拼 URL、better-auth baseURL 也用它）
NEXT_PUBLIC_SITE_URL=http://localhost:3020

# 站点名称（留空用默认）
NEXT_PUBLIC_SITE_NAME=

# root 管理员邮箱（客户端判断是否显示后台入口；服务端判定用 wrangler vars 的 ROOT_USER_EMAIL）
NEXT_PUBLIC_ROOT_USER_EMAIL=

# Google One-Tap 登录 client id（可选）
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Analytics（可选）
NEXT_PUBLIC_GA_ID=

# Awesome Comment 评论系统站点 id（可选）
NEXT_PUBLIC_AWESOME_COMMENT_SITE_ID=

# 应用版本号（可选，页脚展示）
NEXT_PUBLIC_APP_VERSION=

# 无头模式（可选，隐藏站点外壳）
NEXT_PUBLIC_HEADLESS_MODE=

# 博客 CMS API 地址（可选，服务端拉取博客内容）
CMS_API_URL=
