{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "mui-gamebook",
  "compatibility_date": "2026-06-27",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "account_id": "fdc63eeea83ae8f5234357308b9a638b",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mui-gamebook",
      "database_id": "f1e05f17-9197-4344-a106-1fe0f906586f"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "a9863dd8de514dc8940e0da4cf5c76da",
      "preview_id": "a9863dd8de514dc8940e0da4cf5c76da"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": true,
      "persist": true
    }
  },
  "placement": {
    "mode": "smart"
  },
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "baifo"
    },
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "gamebook-assets"
    }
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      // The service should match the "name" of your worker
      "service": "mui-gamebook"
    }
  ],
  // 声明本项目用到的 secret 名单（不含真实值，值仍然只能用 `wrangler secret put` 设置）。
  // 有了这个列表，`wrangler types`/CI 构建不再依赖本机 .dev.vars 就能生成正确的类型，
  // `wrangler dev` 也会在缺少某个 secret 时给出警告。新增 secret 时记得同步这里。
  "secrets": {
    "required": [
      "ADMIN_PASSWORD",
      "BETTER_AUTH_SECRET",
      "GOOGLE_API_KEY",
      "OPENAI_API_KEY",
      "MIMO_API_KEY",
      "CF_AI_GATEWAY_TOKEN",
      "SENDFLARE_KEY",
      "STORY_PRIVATE_KEY",
      "PINATA_JWT"
    ]
  },
  // 注意：NEXT_PUBLIC_* 变量不要放这里。它们由 Next.js 在构建期静态替换进产物，
  // 运行时读取的是打包时的字面量，Workers 的 env 绑定对它们不起作用。
  // 构建前请确保 .env（本地）或构建环境变量里已经填好，见 .env.example。
  "vars": {
    "ASSETS_PUBLIC_DOMAIN": "https://i.muistory.com",
    "COOKIE_DOMAIN": "",
    "CRON_SECRET": "mui-gamebook-cron",
    "GOOGLE_MODEL": "gemini-3-pro-preview",
    "GOOGLE_IMAGE_MODEL": "gemini-2.5-flash-image",
    "GOOGLE_TTS_MODEL": "gemini-2.5-flash-preview-tts",
    "DEFAULT_TTS_VOICE": "Aoede",
    "GOOGLE_VIDEO_MODEL": "veo-3.1-fast-generate-preview",
    "OPENAI_TTS_MODEL": "gpt-4o-mini-tts",
    "OPENAI_VIDEO_MODEL": "sora-2",
    "ROOT_USER_EMAIL": "meathill@gmail.com",
    "RPC_PROVIDER_URL": "https://aeneid.storyrpc.io",
    "SENDER_EMAIL": "noreply@muistory.com",
    "TRUSTED_ORIGINS": "",
    "HEADLESS_MODE": "false"
  }
}
